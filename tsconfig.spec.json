/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "./out-tsc/spec",
        "types": [
            "jasmine"
        ]
    },
    "include": [
        "src/**/*.spec.ts",
        "src/**/*.d.ts"
    ],
    "exclude": [
        "src/app/pages/contacts/utilisateurs/utilisateurs-form/utilisateurs-form.spec.ts",
        "src/app/pages/comptabilite/facture-livraison-detail/facture-livraison-detail.spec.ts",
        "src/app/pages/uikit/**/*",
        "src/app/pages/ecommerce/**/*",
        "src/app/apps/**/*",
        "src/app/pages/blocks/**/*"
    ]
}

{
  "name": "apollo-ng",
  "version": "20.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:e2e": "ng serve --host 127.0.0.1 --port 4200",
    "build": "ng build --configuration production && node scripts/write-version.js",
    "build:preprod": "ng build --configuration preprod && node scripts/write-version.js && node scripts/copy-deploy.js preprod",
    "build:deploy": "ng build --configuration production && node scripts/write-version.js && node scripts/copy-deploy.js production",
    "watch": "ng build --watch --configuration development",
    "format": "prettier --write \"**/*.{js,mjs,ts,mts,d.ts,html}\" --cache",
    "test": "ng test",
    "cypress:open": "set \"ELECTRON_RUN_AS_NODE=\" && cypress open",
    "cypress:run": "set \"ELECTRON_RUN_AS_NODE=\" && cypress run",
    "e2e:produits": "set \"ELECTRON_RUN_AS_NODE=\" && cypress run --e2e --spec cypress/e2e/produits.cy.ts",
    "e2e:produits:ci": "start-server-and-test start:e2e http://127.0.0.1:4200 e2e:produits"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20",
    "@angular/common": "^20",
    "@angular/compiler": "^20",
    "@angular/core": "^20",
    "@angular/forms": "^20",
    "@angular/platform-browser": "^20",
    "@angular/platform-browser-dynamic": "^20",
    "@angular/router": "^20",
    "@angular/service-worker": "^20.3.16",
    "@primeuix/themes": "^1.2.1",
    "@tailwindcss/postcss": "^4.1.11",
    "chart.js": "4.4.2",
    "country-flag-icons": "^1.6.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "libphonenumber-js": "^1.12.34",
    "primeclt": "^0.1.5",
    "primeicons": "^7.0.0",
    "primeng": "^20",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20",
    "@angular/cli": "^20",
    "@angular/compiler-cli": "^20",
    "@types/jasmine": "~5.1.0",
    "autoprefixer": "^10.4.20",
    "cypress": "^14.0.3",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^4.2.1",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.0.0",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3"
  }
}
